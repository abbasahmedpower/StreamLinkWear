# ===================================================
# StreamLinkWear — Optimized .gitignore
# ===================================================

# ── Build outputs (أكبر سبب للحجم الكبير) ─────────
build/
*/build/
**/build/
bin/
*/bin/
**/bin/
.gradle/
*/.gradle/
**/.gradle/
local.properties

# ── Android Studio / IntelliJ / VSCode ──────────────
.idea/
*.iml
*.ipr
*.iws
.DS_Store
.vscode/

# ── AI Tools & Editors Cache (إضافة لحماية كاش المحرر) ──
.cursor/
.continue/

# ── Kotlin / Java ──────────────────────────────────
*.class
*.jar
*.war
*.aar

# ── APK / AAB ──────────────────────────────────────
*.apk
*.aab
*.ap_
*.dex

# ── Signing (مهم جداً — لا ترفع keystore) ─────────
*.jks
*.keystore
*.p12
keystore.properties
signing.properties

# ── NDK ─────────────────────────────────────────────
.cxx/
*.so

# ── Captures / Profiling ────────────────────────────
captures/
*.hprof

# ── Backend Kotlin build ─────────────────────────────
backend/build/
backend/.gradle/

# ── Node / Python ────────────────────────────────────
node_modules/
__pycache__/
*.pyc
*.pyo
.venv/
venv/
dist/

# ── TFLite model (كبير — اتدرب محلياً) ─────────────
*.tflite
ai_training/stream_predict_model.tflite
ai_training/stream_predictor.tflite

# ── Logs ─────────────────────────────────────────────
*.log
logs/

# ── JVM Crash Logs (لا ترفع — معلومات حساسة) ────────
hs_err_pid*.log
replay_pid*.log

# ── Environment ──────────────────────────────────────
.env
.env.local
secrets.properties

# ── Gradle Wrapper (ارفع الملف بس مش الـ jar) ───────
!gradle/wrapper/gradle-wrapper.properties
!gradlew
!gradlew.bat

# YoYo AI version control directory
.yoyo/

testsprite_tests\tmp\config.json
