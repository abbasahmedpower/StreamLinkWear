# StreamLinkWear Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Security ──────────────────────────────────────────────────────────────────
# Secret token for X-Horus-Authorization header authentication
# Must match the token configured in the Android app's BuildConfig
HORUS_SECRET=CHANGE_ME_REPLACE_WITH_STRONG_RANDOM_SECRET

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis URL for cross-node session sharing (leave empty for single-node mode)
REDIS_URL=redis://localhost:6379

# ── Server Node ───────────────────────────────────────────────────────────────
# Unique ID for this backend node (used in Redis pub/sub routing)
NODE_ID=node-1

# ── TURN Server ───────────────────────────────────────────────────────────────
# coturn TURN server credentials (must match Android secrets.properties)
TURN_USERNAME=streamlink
TURN_PASSWORD=CHANGE_ME_STRONG_TURN_PASSWORD
