<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ─── Permissions & Google Play Compliance ───────────────────────────── -->
    <!-- Network & Local Discovery: Required for phone-to-watch TCP/UDP connection -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- Background Services: Required for uninterrupted streaming while app is minimized -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Data Safety Justification: Screen mirroring needs continuous screen capture -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <!-- Data Safety Justification: Maintains a persistent local link to the smartwatch -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- Data Safety Justification: Required to stream internal device audio to the watch -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Android 13+ notification permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Camera permission for QR scanning -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- ─── Queries (Android 11+) — allows opening browser/email — NANO-FIX N2 -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
    </queries>

    <application
        android:name=".StreamLinkApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:localeConfig="@xml/locales_config"
        android:theme="@style/Theme.StreamLink">

        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|uiMode">
        </activity>

        <activity
            android:name=".ui.OnboardingActivity"
            android:exported="true"
            android:label="StreamLink Setup">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- QR Scanner screen — launched when connecting to a watch -->
        <activity
            android:name=".ui.MobileQrScannerActivity"
            android:exported="false"
            android:label="Scan Watch QR"
            android:windowSoftInputMode="adjustResize" />

        <service
            android:name=".capture.CaptureService"
            android:foregroundServiceType="mediaProjection|connectedDevice"
            android:exported="false" />

        <service
            android:name=".control.RemoteControlAccessibilityService"
            android:exported="true"
            android:label="StreamLink Touch Control"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService"/>
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config"/>
        </service>

        <!-- ✅ Phone-side Foreground Service — keeps streaming alive in background -->
        <service
            android:name=".stream.PhoneStreamingForegroundService"
            android:foregroundServiceType="connectedDevice"
            android:exported="false" />

    </application>

</manifest>
