# cp secrets.properties.example secrets.properties
#
# ⚠️  NEVER commit secrets.properties to git!
# ===================================================

# TURN Server credentials (for WebRTC fallback)
TURN_USERNAME=your_turn_username_here
TURN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Horus Backend Secret Token (min 64 chars random string)
# Generate with: openssl rand -hex 32
HORUS_SECRET_TOKEN=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
